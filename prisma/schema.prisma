generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum WhitelistStatus {
  NONE
  INVITED
  ACTIVE
}

enum AgentPackageStatus {
  DRAFT
  VALIDATING
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ConsultationStatus {
  NEW
  IN_DISCUSSION
  SCOPED
  ORDER_CREATED
  CLOSED
}

enum ServiceOrderStatus {
  PENDING_PAYMENT
  PAID
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  role            UserRole        @default(USER)
  whitelistStatus WhitelistStatus @default(NONE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  packages        AgentPackage[]
  sessions        Session[]
  magicLinkTokens MagicLinkToken[]
  buyerConsultations Consultation[] @relation("BuyerConsultations")
  providerConsultations Consultation[] @relation("ProviderConsultations")
  buyerOrders      ServiceOrder[]  @relation("BuyerOrders")
  providerOrders   ServiceOrder[]  @relation("ProviderOrders")
  providerDeliveries Delivery[]    @relation("ProviderDeliveries")
}

model MagicLinkToken {
  id         String   @id @default(cuid())
  email      String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentPackage {
  id               String             @id @default(cuid())
  ownerId          String
  name             String
  slug             String             @unique
  version          String
  summary          String
  categories       String[]
  metadataJson     Json
  zipFileUrl       String
  zipFileName      String
  zipSizeBytes     Int
  coverUrl         String?
  downloadCount    Int                @default(0)
  status           AgentPackageStatus @default(DRAFT)
  validationResult Json
  publishedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  owner            User               @relation(fields: [ownerId], references: [id])
  skills           Skill[]
  workflows        Workflow[]
  consultations    Consultation[]

  @@index([ownerId, createdAt])
  @@index([status, publishedAt])
}

model Skill {
  id             String       @id @default(cuid())
  agentPackageId String
  name           String
  path           String
  description    String

  agentPackage   AgentPackage @relation(fields: [agentPackageId], references: [id], onDelete: Cascade)

  @@index([agentPackageId])
}

model Workflow {
  id             String       @id @default(cuid())
  agentPackageId String
  name           String
  path           String
  description    String

  agentPackage   AgentPackage @relation(fields: [agentPackageId], references: [id], onDelete: Cascade)

  @@index([agentPackageId])
}

model Consultation {
  id             String             @id @default(cuid())
  agentPackageId String
  providerId     String
  buyerEmail     String
  buyerUserId    String?
  requirement    String
  status         ConsultationStatus @default(NEW)
  scopedSummary  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  agentPackage   AgentPackage       @relation(fields: [agentPackageId], references: [id], onDelete: Cascade)
  provider       User               @relation("ProviderConsultations", fields: [providerId], references: [id], onDelete: Cascade)
  buyerUser      User?              @relation("BuyerConsultations", fields: [buyerUserId], references: [id], onDelete: SetNull)
  orders         ServiceOrder[]

  @@index([agentPackageId])
  @@index([providerId, createdAt])
  @@index([buyerEmail, createdAt])
  @@index([buyerUserId])
}

model ServiceOrder {
  id               String             @id @default(cuid())
  consultationId   String
  buyerEmail       String
  buyerUserId      String?
  providerId       String
  title            String
  scope            String
  priceCents       Int
  currency         String
  status           ServiceOrderStatus @default(PENDING_PAYMENT)
  paymentStatus    PaymentStatus      @default(UNPAID)
  paymentProvider  String
  paymentReference String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  consultation     Consultation       @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  buyerUser        User?              @relation("BuyerOrders", fields: [buyerUserId], references: [id], onDelete: SetNull)
  provider         User               @relation("ProviderOrders", fields: [providerId], references: [id], onDelete: Cascade)
  deliveries       Delivery[]

  @@index([consultationId])
  @@index([providerId, createdAt])
  @@index([buyerEmail, createdAt])
  @@index([buyerUserId])
  @@index([status, paymentStatus])
}

model Delivery {
  id            String       @id @default(cuid())
  serviceOrderId String
  providerId    String
  fileUrl       String
  fileName      String
  fileSizeBytes Int
  note          String?
  submittedAt   DateTime     @default(now())
  acceptedAt    DateTime?
  createdAt     DateTime     @default(now())

  serviceOrder  ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  provider      User         @relation("ProviderDeliveries", fields: [providerId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId, submittedAt])
  @@index([providerId, submittedAt])
}
